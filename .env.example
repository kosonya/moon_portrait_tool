# Copy this file to `.env` next to docker-compose.yml and adjust values.

# --- REQUIRED ---------------------------------------------------------------

# Absolute host path of moon_portrait_tool/results.
# This folder gets bind-mounted into the container at /app/results and is
# where all run outputs (CSV, map.html, meta.json, name.txt) land. Sync it
# to Google Drive on both the NAS and your laptop so either host sees the
# same set of runs.

# NAS (Asustor / Synology with Insync to Google Drive):
RESULTS_PATH=/volume1/Mainshare/Insync/sophia.m.kovaleva@gmail.com/Google Drive/proging/moon_photo/Moon portrait/moon_portrait_tool/results

# Laptop alternatives — pick the one that exists:
# RESULTS_PATH=/home/sophia/Insync/sophia.m.kovaleva@gmail.com/Google Drive/proging/moon_photo/Moon portrait/moon_portrait_tool/results
# RESULTS_PATH=/Users/sophia/Insync/sophia.m.kovaleva@gmail.com/Google Drive/proging/moon_photo/Moon portrait/moon_portrait_tool/results

# --- OPTIONAL --------------------------------------------------------------

# Timezone for log timestamps and the "completed_at_local" display in the UI.
# Use any IANA tz name. Default is UTC.
TZ=America/Los_Angeles

# Host port is hardcoded to 5000 in docker-compose.yml. To use a different
# port, edit the `ports:` line there directly — Portainer doesn't reliably
# substitute compose ${VAR:-default} expressions.
